# MediFlow environment template. Copy to `.env` and fill in real values.
#   cp .env.example .env

# --- Database ---------------------------------------------------------------
# Option A (zero-install, recommended for dev): run `npx prisma dev` and paste
# the DATABASE_URL / SHADOW_DATABASE_URL it prints here.
# Option B: point at your own local/hosted Postgres, e.g.
#   postgresql://USER:PASSWORD@localhost:5432/mediflow?schema=public
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"
SHADOW_DATABASE_URL="postgres://postgres:postgres@localhost:51215/template1?sslmode=disable"

# --- Auth.js (NextAuth v5) --------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-a-32-byte-base64-secret"

# --- Google Gemini ----------------------------------------------------------
# Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key"

# Model to use. Free tier: "gemini-flash-lite-latest" (higher daily quota).
# On a billed key, "gemini-flash-latest" gives the best quality.
GEMINI_MODEL="gemini-flash-lite-latest"
